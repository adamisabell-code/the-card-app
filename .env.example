# --- Browser (Vite) — never put OpenAI secrets here ---
# Set true only when `npm run server` is running (or your hosted API implements the same routes).
VITE_AI_AVATAR_ENABLED=false
# Optional absolute base for avatar API (defaults to same-origin `/api/avatars`).
# VITE_AI_AVATAR_SERVER_URL=http://127.0.0.1:8787

# POST /api/receipt-flavor only when both this and server ENABLE_AI_RECEIPT_FLAVOR are true.
VITE_AI_RECEIPT_FLAVOR=false

# --- Node server (`npm run server`) — keep keys off the client ---
OPENAI_API_KEY=

# Receipt one-liner (chat). Defaults to false — must be exactly "true" to enable.
ENABLE_AI_RECEIPT_FLAVOR=false

# Optional overrides
# OPENAI_IMAGE_MODEL=gpt-image-1
# OPENAI_IMAGE_SIZE=1024x1024
# OPENAI_FLAVOR_MODEL=gpt-4o-mini
# PORT=8787
